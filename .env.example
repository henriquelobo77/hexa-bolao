# ============================================================
# HEXA · Bolão Copa 2026 — Environment variables
# Copie este arquivo para .env.local e preencha os valores.
# ============================================================

# Supabase (https://supabase.com → seu projeto → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Senha do admin (será usada na tela /admin)
ADMIN_PASSWORD=trocar-em-prod

# Configuração do bolão (usada apenas no seed)
BOLAO_NAME="Galera do Boteco"
BOLAO_SLUG=galera-do-boteco
BOLAO_JOIN_CODE=HEXA2026

# Sessão (string aleatória pra assinar cookies)
SESSION_SECRET=troque-isso-por-uma-string-aleatoria-de-32-chars

# football-data.org — API esportiva
# Registre em: https://www.football-data.org/client/register
# (tier free serve: 10 req/min)
FOOTBALL_DATA_TOKEN=

# Segredo do cron Vercel (gere uma string aleatória qualquer)
# Vercel envia ele no header Authorization: Bearer <CRON_SECRET>
CRON_SECRET=troque-isso-por-uma-string-aleatoria

# URL pública (opcional — usada pra OG image preview no WhatsApp/Twitter)
# Em produção: https://seu-dominio.vercel.app
# Em dev: deixa em branco (cai pro localhost)
NEXT_PUBLIC_APP_URL=
